# MUSICOTECA environment variables
# Copy this file to .env.local and fill in values as features are wired up.
# These keys are only ever read server-side (in app/api/* route handlers)
# and must never be exposed to the client.

# Musixmatch — track search, lyrics, and lyric analysis
MUSIXMATCH_API_KEY=

# YouTube Data API v3 — official video lookup for each track
YOUTUBE_API_KEY=

# Groq — generates the "Inner World" and "The Moment" exhibit texts
GROQ_API_KEY=

# ElevenLabs — text-to-speech (reserved for the Listen buttons)
ELEVENLABS_API_KEY=
